# Copy to `.env.local` and adjust as needed. All values are optional.

# Which tdl adapter to use:
#   real  (default) — spawn the actual tdl binary
#   mock            — simulate tdl; runs with no binary and no Telegram account
TDL_MODE=real

# Name or absolute path of the tdl binary (must be on PATH if just "tdl").
TDL_BIN=tdl

# Where the app stores its SQLite database and other data.
TDL_DATA_DIR=data

# Default directory downloads are written to.
TDL_DOWNLOAD_DIR=downloads
